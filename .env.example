# ===========================
# 로컬 개발 환경 설정
# ===========================
NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://127.0.0.1:5173
DATABASE_URL=postgresql://taewoong:taewoong@127.0.0.1:5432/taewoong_gas?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
UPLOAD_DRIVER=local
LOCAL_UPLOAD_DIR=./uploads
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=ap-northeast-2
S3_BUCKET=taewoong-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin1234!
SHIFT_DAY_START=08:00
SHIFT_DAY_END=19:30
SHIFT_NIGHT_START=20:00
SHIFT_NIGHT_END=07:00

# ===========================
# Vercel 프로덕션 환경변수 (Vercel 대시보드에서 설정)
# ===========================
# NODE_ENV=production
# DATABASE_URL=postgresql://<USER>:<PASS>@<HOST>/<DB>?sslmode=require
#   → Neon: https://neon.tech
#   → Supabase: https://supabase.com
#   → Railway: https://railway.app
# JWT_SECRET=<64자 이상의 랜덤 문자열>
# WEB_ORIGIN=https://<your-project>.vercel.app
# UPLOAD_DRIVER=s3   (파일 업로드를 S3/R2로 처리할 경우)
# S3_ENDPOINT=<Cloudflare R2 또는 AWS S3 엔드포인트>
# S3_REGION=ap-northeast-2
# S3_BUCKET=<버킷 이름>
# S3_ACCESS_KEY=<액세스 키>
# S3_SECRET_KEY=<시크릿 키>
