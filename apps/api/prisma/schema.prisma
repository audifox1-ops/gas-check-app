generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum Shift {
  DAY
  NIGHT
}

enum EntrySource {
  AUTO
  MANUAL
  PASTE
}

enum ScanStatus {
  UPLOADED
  REVIEWING
  COMPLETE
  FAILED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Furnace {
  id            String         @id @default(cuid())
  no            Int            @unique
  name          String
  importBatches ImportBatch[]
  readings      GasReading[]
  chargeEntries ChargeEntry[]
  chargeRecords ChargeRecord[]
  gasUsages     GasUsage[]
}

model ImportBatch {
  id          String       @id @default(cuid())
  fileName    String
  furnaceId   String
  furnace     Furnace     @relation(fields: [furnaceId], references: [id])
  periodStart DateTime?
  periodEnd   DateTime?
  rowCount    Int          @default(0)
  successCount Int         @default(0)
  errorCount  Int          @default(0)
  status      String       @default("pending")
  errors      Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  readings    GasReading[]

  @@index([furnaceId, createdAt])
}

model GasReading {
  id                BigInt      @id @default(autoincrement())
  furnaceId         String
  furnace           Furnace     @relation(fields: [furnaceId], references: [id])
  ts                DateTime
  temp              Decimal?    @db.Decimal(12, 3)
  gas               Decimal?    @db.Decimal(12, 3)
  gasCumulative     Decimal     @db.Decimal(18, 3)
  power             Decimal?    @db.Decimal(12, 3)
  powerCumulative   Decimal?    @db.Decimal(18, 3)
  temp2             Decimal?    @db.Decimal(12, 3)
  temp3             Decimal?    @db.Decimal(12, 3)
  importBatchId     String
  importBatch       ImportBatch @relation(fields: [importBatchId], references: [id])
  createdAt         DateTime    @default(now())

  @@unique([furnaceId, ts])
  @@index([furnaceId, ts])
  @@index([importBatchId])
}

model ChargeScan {
  id               String         @id @default(cuid())
  fileUrl          String
  storageKey       String
  originalFileName String
  pageCount        Int
  status           ScanStatus     @default(UPLOADED)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  records          ChargeRecord[]
}

model ChargeRecord {
  id           String       @id @default(cuid())
  chargeScanId String
  chargeScan   ChargeScan   @relation(fields: [chargeScanId], references: [id], onDelete: Cascade)
  pageIndex    Int
  furnaceId    String
  furnace      Furnace      @relation(fields: [furnaceId], references: [id])
  workDate     DateTime     @db.Date
  shift        Shift
  workEnd      DateTime
  workStart    DateTime?
  material     String?
  weightKg     Decimal?     @db.Decimal(12, 3)
  note         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  entries      ChargeEntry[]
  gasUsages    GasUsage[]

  @@unique([chargeScanId, pageIndex])
  @@index([furnaceId, workDate, shift, workEnd])
}

model ChargeEntry {
  id             String       @id @default(cuid())
  chargeNo       String       @unique
  furnaceId      String
  furnace        Furnace      @relation(fields: [furnaceId], references: [id])
  gasBefore      Decimal?     @db.Decimal(18, 3)
  gasAfter       Decimal?     @db.Decimal(18, 3)
  usage          Decimal?     @db.Decimal(18, 3)
  workDate       DateTime     @db.Date
  shift          Shift
  source         EntrySource  @default(MANUAL)
  chargeRecordId String?
  chargeRecord   ChargeRecord? @relation(fields: [chargeRecordId], references: [id], onDelete: SetNull)
  note           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  gasUsage       GasUsage?

  @@index([furnaceId, workDate, shift])
  @@index([chargeRecordId])
}

model GasUsage {
  id             String       @id @default(cuid())
  furnaceId      String
  furnace        Furnace      @relation(fields: [furnaceId], references: [id])
  workDate       DateTime     @db.Date
  shift          Shift
  cumStart       Decimal?     @db.Decimal(18, 3)
  cumEnd         Decimal?     @db.Decimal(18, 3)
  usage          Decimal?     @db.Decimal(18, 3)
  weightKg       Decimal?     @db.Decimal(12, 3)
  unitRate       Decimal?     @db.Decimal(18, 6)
  chargeEntryId  String?      @unique
  chargeEntry    ChargeEntry? @relation(fields: [chargeEntryId], references: [id], onDelete: SetNull)
  chargeRecordId String?
  chargeRecord   ChargeRecord? @relation(fields: [chargeRecordId], references: [id], onDelete: Cascade)
  warnings       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([chargeRecordId])
  @@index([furnaceId, workDate, shift])
}
