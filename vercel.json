{
  "version": 2,
  "buildCommand": "npm run build -w packages/shared && npm run build -w apps/web",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/uploads/(.*)", "destination": "/api/index.ts" },
    { "source": "/((?!_next/static|_next/image|favicon.ico).*)", "destination": "/index.html" }
  ]
}
